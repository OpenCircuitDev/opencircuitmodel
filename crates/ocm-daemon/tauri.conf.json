{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCircuitModel",
  "version": "0.1.0",
  "identifier": "org.opencircuitmodel.daemon",
  "build": {
    "frontendDist": "../../frontend/build",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "OpenCircuitModel",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "publisher": "OpenCircuitDev",
    "copyright": "Copyright (C) 2026 OpenCircuit Dev. Apache-2.0 licensed.",
    "category": "DeveloperTool",
    "shortDescription": "Free personal AI agent — local, persistent, mesh-ready.",
    "longDescription": "OpenCircuitModel (OCM) runs a personal AI agent on your own hardware. Persistent memory across sessions via Mem0, OpenAI-compatible HTTP and MCP server APIs, and zero mesh dependencies in v1. Connects to llama.cpp on Apple Silicon or vLLM on NVIDIA out of the box.",
    "homepage": "https://ocm.shortcircuit.bot",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
