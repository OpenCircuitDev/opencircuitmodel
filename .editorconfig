# EditorConfig: https://editorconfig.org
# Keeps formatting consistent across editors so contributors don't fight
# fmt-check / svelte-check on whitespace differences.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Languages with established conventions that differ from the project default
[*.{js,jsx,ts,tsx,svelte,html,css,json,yaml,yml,md}]
indent_size = 2

[*.toml]
indent_size = 2

[Cargo.toml]
indent_size = 4

[*.{py,rs}]
indent_size = 4

# Markdown trailing-whitespace is sometimes meaningful (line break)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab
